<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  {{#if googleFont}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family={{ fontFamily }}:wght@400;600;700&display=swap" rel="stylesheet" />
  {{/if}}
  <style>
    :root {
      --bg:      {{ theme.background }};
      --surface: {{ theme.surface }};
      --accent:  {{ theme.accent }};
      --text:    {{ theme.text }};
      --radius:  {{ theme.radius }};
      --font:    {{ fontStack }};
      {{#if theme.border}}--border: {{ theme.border }};{{/if}}
    }
    {{{ css }}}
  </style>
</head>
<body>
  <main>
    <header class="profile">
      {{#if avatar}}
      <img class="avatar" src="{{ avatar }}" alt="{{ title }}" />
      {{/if}}
      <h1>{{ title }}</h1>
      {{#if bio}}
      <p class="bio">{{ bio }}</p>
      {{/if}}
    </header>

    <div class="columns">
      <nav class="links">
        {{#each links}}
        <a class="link-btn" href="{{ url }}" target="_blank" rel="noopener noreferrer">
          {{#if iconSvg}}
          <span class="icon">{{{ iconSvg }}}</span>
          {{/if}}
          {{ label }}
        </a>
        {{/each}}
      </nav>

      {{#if posts.length}}
      <section class="posts{{#if portfolioLayout}} posts--grid{{/if}}">
        {{#each posts}}
        <a class="post-card" href="{{ url }}">
          <div class="post-header">
            <span class="post-title">{{ title }}</span>
            {{#if date}}<span class="post-date">{{ date }}</span>{{/if}}
          </div>
          {{#if subtitle}}<p class="post-subtitle">{{ subtitle }}</p>{{/if}}
          {{#if preview}}<div class="post-preview">{{ preview }}</div>{{/if}}
        </a>
        {{/each}}
      </section>
      {{/if}}
    </div>
  </main>
</body>
</html>
